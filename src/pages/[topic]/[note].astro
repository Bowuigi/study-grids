---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  return allNotes.map(note => {
    const [topic, slug] = note.id.split('/');
    return {
      params: { topic, note: slug }
    };
  });
}

const { topic, note: noteSlug } = Astro.params;
const allNotes = await getCollection('notes');
const entry = allNotes.find(n => n.id === `${topic}/${noteSlug}`);

if (!entry) throw new Error(`Note not found ${topic}/${noteSlug}`);

const { Content } = await render(entry);
---

<style>
  .note-title {
    text-align: center;
    font-weight: 500;
    font-size: 3rem;
    margin-top: 1rem;
    margin-bottom: 2rem;
  }
</style>

<Layout>
  <div class="note-title">{entry.data.title}</div>
  <Content />
</Layout>
